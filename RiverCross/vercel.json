{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nitro",
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output/static",
  "installCommand": "npm install",
  "functions": {
    "functions/**/*.mjs": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/__server.func/index.mjs"
    }
  ]
}