{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nitro",
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output/static",
  "installCommand": "npm install",
  "functions": {
    "functions/**/*.mjs": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  }
}